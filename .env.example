# Gemini API credentials — set these as environment variables in Vercel (or your deployment platform).
#
# Despite the NEXT_PUBLIC_ prefix (kept for compatibility with already-configured Vercel secrets),
# these values are read ONLY by the /api/gemini serverless function and are NEVER sent to the browser.
# The prefix has no special meaning in this project because it is not a Next.js application.
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_GEMINI_URL_KEY=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent
